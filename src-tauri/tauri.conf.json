{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Typertype",
  "version": "0.4.2",
  "identifier": "com.tylike.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Typertype",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "shortDescription": "Typora benzeri açık kaynak Windows markdown editörü",
    "longDescription": "Typertype, ProseMirror tabanlı WYSIWYG markdown editörüdür. KaTeX, Mermaid, GFM tablo ve dipnot desteğiyle Typora deneyimini açık kaynak olarak sunar.",
    "publisher": "Typertype",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown belgesi",
        "role": "Editor"
      },
      {
        "ext": ["txt"],
        "name": "Text Document",
        "description": "Düz metin belgesi",
        "role": "Editor"
      }
    ],
    "windows": {
      "wix": {
        "language": ["en-US", "tr-TR"]
      },
      "nsis": {
        "languages": ["English", "Turkish"],
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "installerHooks": "installer.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/KatincBK/typertype/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5N0MyRjg3Q0VEQjA3N0MKUldSOEI5dk9oeTk4ZVh2SzVBWEhNM09tQzZONUJ2aGhuQjNJUVUxbXJFa1FIaGpEYjFzOEY3aDYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
